# Copy to .env and fill in.  DO NOT commit .env.

# Master KEK (32 random bytes, hex).  Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
D1BOT_KEK_HEX=

# JWT signing secret (also 32+ random bytes hex).
JWT_SECRET=

# Database (Supabase pooler URL works fine)
DATABASE_URL=postgresql://user:pass@localhost:5432/d1saas

# Stripe (test keys for local dev; live keys for production)
STRIPE_SECRET_KEY=sk_test_xxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxx
STRIPE_PRICE_ID=price_xxxxxxx

# Hosts / CORS (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# Environment flag
ENV=development
